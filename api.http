
### Create a ticket
POST http://localhost:8080/api/tickets
Content-Type: application/json

{
  "title": "LogIn issue after reset",
  "description": "Can't log in. The system shows an error message.",
  "category": "ACCOUNT",
  "priority": "HIGH",
  "createdByUserId": "usr_9f62e110",
  "tags": ["login", "account"],
  "customFields": {
    "browser": "Chrome",
    "os": "macOS"
  }
}

### Create a user
POST http://localhost:8080/api/users
Content-Type: application/json

{
  "email": "hb@example.com",
  "password": "ChangeMe123!",
  "firstName": "habib",
  "lastName": "wahid",
  "role": "AGENT",
  "isActive": true,
  "emailVerified": false,
  "department": "GENERAL",
  "managerId": "usr_admin001"
}
